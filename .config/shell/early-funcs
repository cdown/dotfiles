# vim: ft=sh

use_first_to_exist() {
    for command; do
        if command -v "$command" >/dev/null 2>&1; then
            printf '%s\n' "$command"
            return 0
        fi
    done

    echo false
    return 1
}

_UNAME_S=$(uname -s)
_on_macos() { [ "$_UNAME_S" = Darwin ]; }
_on_linux() { [ "$_UNAME_S" = Linux ]; }

_running_on_wsl() {
    is-wsl
}

setopt NULL_GLOB >/dev/null 2>&1

# shellcheck disable=SC2039
shopt -s nullglob >/dev/null 2>&1
